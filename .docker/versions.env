DUST_VER=v1.2.4            # v-prefixed format
PROCS_VER=v0.14.11         # v-prefixed format
DIRENV_VER=v2.37.1         # v-prefixed format
FASTFETCH_VER=2.61.0       # bare version format
GO_VER=go1.26.2            # go-prefixed format
